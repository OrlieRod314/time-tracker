#!/usr/bin/env bash
# timetrack — TUI time tracker with seamless charge code switching

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/time-tracker"
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/time-tracker"
CODES_FILE="$CONFIG_DIR/codes"
SETTINGS_FILE="$CONFIG_DIR/settings"

mkdir -p "$CONFIG_DIR" "$DATA_DIR"
[[ -f "$CODES_FILE" ]]    || touch "$CODES_FILE"
[[ -f "$SETTINGS_FILE" ]] || touch "$SETTINGS_FILE"

TODAY=$(date +%Y-%m-%d)
LOG_FILE="$DATA_DIR/$TODAY.csv"
STATE_FILE="$DATA_DIR/state"   # persists the active session across crashes

[[ -f "$LOG_FILE" ]] || printf 'timestamp,code,description,seconds\n' > "$LOG_FILE"

# ── global tracking state ──────────────────────────────────────────────────
ACTIVE_CODE=''
ACTIVE_DESC=''
ACTIVE_START=0   # epoch seconds; 0 means nothing is running

# ── helpers ────────────────────────────────────────────────────────────────

fmt_dur() {
    local s=$1
    printf '%02d:%02d:%02d' $((s/3600)) $((s%3600/60)) $((s%60))
}

fmt_dec() {
    # Tenths of an hour, rounded (e.g. 3600s → "1.0", 5580s → "1.6")
    local s=$1
    local tenths=$(( (s + 180) / 360 ))
    printf '%d.%d' $(( tenths / 10 )) $(( tenths % 10 ))
}

get_setting() {
    grep -m1 "^${1}=" "$SETTINGS_FILE" 2>/dev/null | cut -d= -f2-
}

set_setting() {
    local key=$1 val=$2
    local rest
    rest=$(grep -v "^${key}=" "$SETTINGS_FILE" 2>/dev/null || true)
    { [[ -n "$rest" ]] && printf '%s\n' "$rest"; printf '%s=%s\n' "$key" "$val"; } \
        > "$SETTINGS_FILE"
}

load_codes() {
    mapfile -t CODES < "$CODES_FILE" 2>/dev/null || CODES=()
    local f=()
    for c in "${CODES[@]+"${CODES[@]}"}"; do [[ -n "$c" ]] && f+=("$c"); done
    CODES=("${f[@]+"${f[@]}"}")
}

save_codes() {
    printf '%s\n' "${CODES[@]+"${CODES[@]}"}" > "$CODES_FILE"
}

load_today_totals() {
    declare -gA TOTALS=()
    [[ -f "$LOG_FILE" ]] || return
    local ts code desc secs
    while IFS=, read -r ts code desc secs; do
        [[ "$ts" == "timestamp" ]] && continue
        TOTALS["$code"]=$(( ${TOTALS["$code"]:-0} + secs ))
    done < "$LOG_FILE"
}

log_entry() {
    local code=$1 desc=$2 secs=$3
    [[ $secs -le 0 ]] && return
    printf '%s,%s,%s,%s\n' "$(date +%H:%M:%S)" "$code" "$desc" "$secs" \
        >> "$LOG_FILE"
}

# ── state file (crash recovery) ────────────────────────────────────────────

save_state() {
    printf 'code=%s\ndesc=%s\nstart=%s\n' \
        "$ACTIVE_CODE" "$ACTIVE_DESC" "$ACTIVE_START" > "$STATE_FILE"
}

clear_state() {
    rm -f "$STATE_FILE"
}

# On startup: if the state file exists, either resume (same day) or log the
# orphaned session to the correct day's file (previous day / crash).
restore_state() {
    [[ -f "$STATE_FILE" ]] || return
    local code desc start
    code=$(grep  '^code='  "$STATE_FILE" | cut -d= -f2-)
    desc=$(grep  '^desc='  "$STATE_FILE" | cut -d= -f2-)
    start=$(grep '^start=' "$STATE_FILE" | cut -d= -f2-)
    rm -f "$STATE_FILE"

    [[ -z "$code" || -z "$start" ]] && return
    local now; now=$(date +%s)
    [[ $start -le 0 || $start -gt $now ]] && return   # corrupted

    local start_date
    start_date=$(date -d "@$start" +%Y-%m-%d 2>/dev/null \
              || date -r  "$start" +%Y-%m-%d 2>/dev/null) || return

    if [[ "$start_date" == "$TODAY" ]]; then
        ACTIVE_CODE=$code
        ACTIVE_DESC=$desc
        ACTIVE_START=$start
        save_state   # re-arm for the resumed session
    else
        # Orphaned session from a previous day — append to that day's log
        local old_log="$DATA_DIR/$start_date.csv"
        [[ -f "$old_log" ]] || printf 'timestamp,code,description,seconds\n' > "$old_log"
        printf '%s,%s,%s,%s\n' \
            "$(date +%H:%M:%S)" "$code" "$desc" "$(( now - start ))" >> "$old_log"
    fi
}

# ── session control ────────────────────────────────────────────────────────

stop_active() {
    [[ -z "$ACTIVE_CODE" || $ACTIVE_START -eq 0 ]] && return
    log_entry "$ACTIVE_CODE" "$ACTIVE_DESC" "$(( $(date +%s) - ACTIVE_START ))"
    clear_state
    ACTIVE_CODE='' ACTIVE_DESC='' ACTIVE_START=0
}

switch_to() {
    stop_active
    ACTIVE_CODE=$1
    ACTIVE_DESC=$2
    ACTIVE_START=$(date +%s)
    save_state
}

# ── pure bash TUI primitives ───────────────────────────────────────────────

# Arrow-key menu. Displays items with a > cursor, Enter to select, q/Esc to
# cancel. Sets REPLY to the selected index; returns 1 on cancel.
_menu() {
    local prompt=$1; shift
    local items=("$@")
    local n=${#items[@]} sel=0 key seq

    tput cnorm
    while true; do
        clear
        printf '%s\n\n' "$prompt"
        for (( i=0; i<n; i++ )); do
            [[ $i -eq $sel ]] \
                && printf ' > %s\n' "${items[$i]}" \
                || printf '   %s\n' "${items[$i]}"
        done
        printf '\n  arrows / Enter / q\n'

        IFS= read -r -s -n1 key
        if [[ "$key" == $'\x1b' ]]; then
            IFS= read -r -s -n2 -t0.1 seq || seq=''
            case "$seq" in
                '[A') (( sel > 0   )) && (( sel-- )) || true ;;
                '[B') (( sel < n-1 )) && (( sel++ )) || true ;;
                *)    tput civis; return 1 ;;
            esac
        else
            case "$key" in
                ''|$'\n') tput civis; REPLY=$sel; return 0 ;;
                q|Q)      tput civis; return 1 ;;
            esac
        fi
    done
}

# Read a line of text into REPLY. Returns 1 on Ctrl-D.
_input() {
    clear
    printf '%s\n> ' "$1"
    tput cnorm
    IFS= read -r REPLY || { tput civis; return 1; }
    tput civis
}

# Single-keystroke yes/no. Returns 0 for y/Y, 1 otherwise.
_confirm() {
    clear
    printf '%s [y/N] ' "$1"
    tput cnorm
    IFS= read -r -n1 REPLY
    printf '\n'
    tput civis
    [[ "${REPLY,,}" == 'y' ]]
}

# Print a message and wait for Enter.
_msg() {
    clear
    printf '%s\n\npress Enter...' "$1"
    tput cnorm
    IFS= read -r _
    tput civis
}

# ── screen drawing ─────────────────────────────────────────────────────────

draw_screen() {
    local now=$(date +%s)
    local session_elapsed=0
    [[ $ACTIVE_START -gt 0 ]] && session_elapsed=$(( now - ACTIVE_START ))

    load_today_totals
    load_codes

    # Merge completed sessions + live session for display
    declare -A DISP=()
    for k in "${!TOTALS[@]}"; do DISP["$k"]=${TOTALS[$k]}; done
    if [[ -n "$ACTIVE_CODE" ]]; then
        DISP["$ACTIVE_CODE"]=$(( ${DISP["$ACTIVE_CODE"]:-0} + session_elapsed ))
    fi

    local W=50
    _sep() { printf '%*s\n' "$W" '' | tr ' ' '-'; }

    tput cup 0 0

    # ── header ────────────────────────────────────────────────────────────────
    local datestr; datestr=$(date '+%a %Y-%m-%d')
    printf 'TIME TRACKER  %s\n' "$datestr"
    _sep

    # ── active code ───────────────────────────────────────────────────────────
    if [[ -n "$ACTIVE_CODE" ]]; then
        local today_total=${DISP["$ACTIVE_CODE"]:-0}
        printf '> %s -- %s\n' "$ACTIVE_CODE" "$ACTIVE_DESC"
        printf '  session %s   today %s  %s\n' \
            "$(fmt_dur $session_elapsed)" "$(fmt_dec $today_total)" "$(fmt_dur $today_total)"
    else
        printf '> (none)  --  press [s] to pick a code\n'
        printf '\n'
    fi
    _sep

    # ── today's log ───────────────────────────────────────────────────────────
    printf 'TODAY\n\n'

    local grand=0
    if [[ ${#CODES[@]} -eq 0 ]]; then
        printf '  no charge codes yet -- press [m] to add some\n'
    else
        local i=1
        for entry in "${CODES[@]}"; do
            local code="${entry%%:*}"
            local desc="${entry#*:}"
            local secs=${DISP["$code"]:-0}
            grand=$(( grand + secs ))
            local mark=' '
            [[ "$code" == "$ACTIVE_CODE" ]] && mark='>'
            local num_lbl
            [[ $i -le 9 ]] && num_lbl="[$i]" || num_lbl='   '
            printf '%s %s %s  %s  %s  %s\n' \
                "$num_lbl" "$mark" "$(fmt_dec $secs)" "$(fmt_dur $secs)" "$code" "$desc"
            (( i++ )) || true
        done
        printf '\n'
        printf '        %s  %s  TOTAL\n' "$(fmt_dec $grand)" "$(fmt_dur $grand)"
    fi
    _sep

    # ── key legend ────────────────────────────────────────────────────────────
    printf '[1-9]  [s]elect  [d]efault  [m]anage  [q]uit\n'

    tput ed 2>/dev/null || true
}

# ── pickers / forms ────────────────────────────────────────────────────────

pick_code() {
    load_codes
    if [[ ${#CODES[@]} -eq 0 ]]; then
        _msg 'no charge codes configured. add some with [m].'
        return 1
    fi
    load_today_totals
    local now; now=$(date +%s)
    local labels=()
    for entry in "${CODES[@]}"; do
        local c="${entry%%:*}" d="${entry#*:}"
        local s=${TOTALS["$c"]:-0}
        [[ "$c" == "$ACTIVE_CODE" && $ACTIVE_START -gt 0 ]] && \
            s=$(( s + now - ACTIVE_START ))
        labels+=("$c  $d  [$(fmt_dur $s)]")
    done
    _menu 'select charge code:' "${labels[@]}" || return 1
    local entry="${CODES[$REPLY]}"
    switch_to "${entry%%:*}" "${entry#*:}"
}

do_add_code() {
    _input 'charge code (e.g. PROJ-001):' || return
    local code
    code=$(printf '%s' "$REPLY" | tr -d ',\n' | xargs 2>/dev/null || true)
    [[ -z "$code" ]] && return

    load_codes
    for e in "${CODES[@]+"${CODES[@]}"}"; do
        if [[ "${e%%:*}" == "$code" ]]; then
            _msg "code '$code' already exists."
            return
        fi
    done

    _input "description for $code:" || return
    local desc
    desc=$(printf '%s' "$REPLY" | tr -d ',\n' | xargs 2>/dev/null || true)
    [[ -z "$desc" ]] && desc="$code"

    CODES+=("$code:$desc")
    save_codes
}

do_delete_code() {
    load_codes
    [[ ${#CODES[@]} -eq 0 ]] && _msg 'no codes to delete.' && return

    local labels=()
    for e in "${CODES[@]}"; do labels+=("${e%%:*}  ${e#*:}"); done
    _menu 'delete which code?' "${labels[@]}" || return
    local idx=$REPLY
    local code="${CODES[$idx]%%:*}"

    _confirm "delete '$code'?" || return

    local def; def=$(get_setting default_code)
    [[ "$def" == "$code" ]] && set_setting default_code ''
    [[ "$ACTIVE_CODE" == "$code" ]] && stop_active

    local new=()
    for e in "${CODES[@]}"; do [[ "${e%%:*}" != "$code" ]] && new+=("$e"); done
    CODES=("${new[@]+"${new[@]}"}")
    save_codes
}

do_set_default() {
    load_codes
    [[ ${#CODES[@]} -eq 0 ]] && _msg 'no codes configured.' && return

    local cur; cur=$(get_setting default_code)
    local labels=("(none)  don't auto-start on launch")
    for e in "${CODES[@]}"; do labels+=("${e%%:*}  ${e#*:}"); done

    _menu "set default startup code  (current: ${cur:-(none)})" "${labels[@]}" || return

    if [[ $REPLY -eq 0 ]]; then
        set_setting default_code ''
    else
        local entry="${CODES[$(( REPLY - 1 ))]}"
        set_setting default_code "${entry%%:*}"
    fi
}

manage_codes() {
    local actions=('add a code' 'delete a code' 'set default startup code' 'back')
    while true; do
        _menu 'manage codes:' "${actions[@]}" || break
        case $REPLY in
            0) do_add_code ;;
            1) do_delete_code ;;
            2) do_set_default ;;
            3) break ;;
        esac
    done
}

# ── main ───────────────────────────────────────────────────────────────────

main() {
    local cleanup_done=false
    cleanup() {
        $cleanup_done && return
        cleanup_done=true
        stop_active
        tput cnorm
        tput rmcup 2>/dev/null || clear
    }
    trap cleanup EXIT INT TERM

    tput smcup
    tput civis
    clear

    # Resume a session that was running when the program last died uncleanly
    restore_state

    # Auto-start the default code only if no session was restored
    if [[ -z "$ACTIVE_CODE" ]]; then
        load_codes
        local def; def=$(get_setting default_code)
        if [[ -n "$def" ]]; then
            for entry in "${CODES[@]+"${CODES[@]}"}"; do
                if [[ "${entry%%:*}" == "$def" ]]; then
                    switch_to "$def" "${entry#*:}"
                    break
                fi
            done
        fi
    fi

    local key
    while true; do
        draw_screen
        key=''
        IFS= read -r -s -n1 -t1 key 2>/dev/null && {
            case "$key" in
                q|Q) break ;;
                s|S) pick_code ;;
                m|M) manage_codes ;;
                d|D) do_set_default ;;
                [1-9])
                    load_codes
                    local idx=$(( key - 1 ))
                    if [[ $idx -lt ${#CODES[@]} ]]; then
                        local entry="${CODES[$idx]}"
                        switch_to "${entry%%:*}" "${entry#*:}"
                    fi
                    ;;
            esac
        } || true
    done
}

main "$@"
